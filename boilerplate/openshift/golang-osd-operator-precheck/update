#!/usr/bin/env bash

set -e

source $CONVENTION_ROOT/_lib/common.sh

# No PRE
[[ "$1" == "PRE" ]] && exit 0

# Expect POST
[[ "$1" == "POST" ]] || err "Got a parameter I don't understand: '$1'. Did the infrastructure change?"

REPO_ROOT=$(git rev-parse --show-toplevel)
OPERATOR_NAME=$(sed -n 's/.*OperatorName .*=.*"\([^"]*\)".*/\1/p' "${REPO_ROOT}/config/config.go")
OPERATOR_NAMESPACE=$(sed -n 's/.*OperatorNamespace .*=.*"\([^"]*\)".*/\1/p' "${REPO_ROOT}/config/config.go")
E2E_SUITE_DIRECTORY=$REPO_ROOT/test/e2e

OPERATOR_UNDERSCORE_NAME=${OPERATOR_NAME//-/_}

mkdir -p "${E2E_SUITE_DIRECTORY}"

# Check for existing BeforeSuite that would conflict
if grep -rq 'BeforeSuite\|SynchronizedBeforeSuite' "${E2E_SUITE_DIRECTORY}"/*.go 2>/dev/null; then
  existing=$(grep -rl 'BeforeSuite\|SynchronizedBeforeSuite' "${E2E_SUITE_DIRECTORY}"/*.go | grep -v '_precheck_test.go' | grep -v 'operator_precheck.go' || true)
  if [[ -n "$existing" ]]; then
    echo "WARNING: Existing BeforeSuite found in: ${existing}"
    echo "         The precheck convention generates a BeforeSuite. Only one is allowed per package."
    echo "         Move existing setup logic into BeforeEach or BeforeAll inside a Describe block."
  fi
fi

# Copy the precheck implementation (always overwritten)
echo "syncing ${E2E_SUITE_DIRECTORY}/operator_precheck.go"
cp "$(dirname $0)/operator_precheck.go" "${E2E_SUITE_DIRECTORY}/operator_precheck.go"

# Generate the BeforeSuite wrapper with operator name substituted
echo "syncing ${E2E_SUITE_DIRECTORY}/${OPERATOR_UNDERSCORE_NAME}_precheck_test.go"
tee "${E2E_SUITE_DIRECTORY}/${OPERATOR_UNDERSCORE_NAME}_precheck_test.go" <<EOF
// THIS FILE IS GENERATED BY BOILERPLATE. DO NOT EDIT.
//go:build osde2e

package osde2etests

import (
	"context"
	"os"

	"github.com/onsi/ginkgo/v2"
	"github.com/onsi/gomega"
	"k8s.io/client-go/rest"
	"k8s.io/client-go/tools/clientcmd"
)

var _ = ginkgo.BeforeSuite(func(ctx context.Context) {
	var cfg *rest.Config
	var err error

	if kubeconfig := os.Getenv("KUBECONFIG"); kubeconfig != "" {
		cfg, err = clientcmd.BuildConfigFromFlags("", kubeconfig)
	} else {
		cfg, err = rest.InClusterConfig()
	}
	gomega.Expect(err).NotTo(gomega.HaveOccurred(), "failed to load cluster config")

	expectedVersion := os.Getenv("OPERATOR_EXPECTED_VERSION")

	err = runOperatorPreChecks(
		ctx,
		ginkgo.GinkgoLogr,
		cfg,
		"${OPERATOR_NAME}",
		"${OPERATOR_NAMESPACE}",
		expectedVersion,
	)
	gomega.Expect(err).NotTo(gomega.HaveOccurred(), "operator pre-checks failed")
})
EOF
